[Unit]
Description=Optificial FastAPI Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/opt/optificial/Chatbox_mcp/backend
EnvironmentFile=/etc/optificial/backend.env
ExecStart=/opt/optificial/venv-backend/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
