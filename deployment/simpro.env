# ═══════════════════════════════════════════════════════════════════════════
# simpro.env — Optificial Simpro MCP Server
# ═══════════════════════════════════════════════════════════════════════════
# The MCP server is a protocol bridge to Simpro ERP.
# Simpro credentials are stored per-org in the database and passed
# dynamically by the backend — they are NOT configured here.
# ═══════════════════════════════════════════════════════════════════════════

# ── MCP Server Binding ───────────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/mcp-server.log

# ── Optional Features ───────────────────────────────────────────────────
ENABLE_CACHING=false
ENABLE_METRICS=true
ENABLE_PRESENTER=true

# ── Agent Service URLs (Docker-internal) ─────────────────────────────────
# These point to the backend container which hosts all agents
INVOICE_AGENT_URL=http://backend:8001
WORKORDER_AGENT_URL=http://backend:8001
EXTRACTOR_AGENT_URL=http://extractor:8010
