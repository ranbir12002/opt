# ═══════════════════════════════════════════════════════════════════════════
# extractor.env — Optificial Document Extractor Service
# ═══════════════════════════════════════════════════════════════════════════
# Minimal config — the extractor is a stateless document processing service.
# It receives files via HTTP POST and returns structured text.
# ═══════════════════════════════════════════════════════════════════════════

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Environment ──────────────────────────────────────────────────────────
ENVIRONMENT=production
