# ═══════════════════════════════════════════════════════════════════════════
# backend.env — Optificial Backend + Agent Services
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT: Never commit this file with real secrets to version control.
# Copy this template, fill in the values, and keep it at:
#   /opt/optificial/deployment/backend.env
# ═══════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────
# Points to the Docker Compose postgres container (service name = postgres)
DATABASE_URL=postgresql://optificial:optificial_prod_2026@postgres:5432/optificial

# ── Encryption ───────────────────────────────────────────────────────────
# Fernet key for encrypting Simpro credentials at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  NEVER change after first use — existing encrypted data becomes unreadable.
FERNET_KEY=CHANGE_ME_GENERATE_A_REAL_KEY

# ── LLM Configuration ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-CHANGE_ME
LLM_MODEL=gpt-4.1-mini
# LLM_PROVIDER=openai
# LLM_API_KEY=                    # Alternative to OPENAI_API_KEY

# Uncomment for Anthropic:
# ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Uncomment for Gemini:
# GEMINI_API_KEY=CHANGE_ME
# GEMINI_MODEL=gemini-2.5-flash

# ── MCP Server (Simpro) ─────────────────────────────────────────────────
# Docker-internal URL — points to the simpro container
MCP_SERVER_URL=http://simpro:8000

# ── Extractor Service ────────────────────────────────────────────────────
# Docker-internal URL — points to the extractor container
EXTRACTOR_URL=http://extractor:8010/extract
EXTRACTOR_TIMEOUT_S=60

# ── Authentication ───────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET
SUPERADMIN_TOKEN=CHANGE_ME_STRONG_TOKEN

# ── Environment ──────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Feature Flags ────────────────────────────────────────────────────────
PII_FILTER_ENABLED=true
USE_PYTHON_EXECUTOR=true
ENABLE_SMART_ROUTING=false
PREFER_COST_OPTIMIZATION=false
ENABLE_QUERY_DECOMPOSER=false
ENABLE_PROMPT_CACHING=true

# ── Personality ──────────────────────────────────────────────────────────
PERSONALITY_PRESET=advisor

# ── Subdomain Branding ───────────────────────────────────────────────────
BASE_DOMAIN=optificial.com

# ── Presenter ────────────────────────────────────────────────────────────
VITE_PRESENTER_BASE=http://127.0.0.1:9000
PRESENTER_USE_LLM_SCHEMA_HINTS=true
PRESENTER_TELEMETRY_SINK=console

# ── AWS S3 (File Uploads) ───────────────────────────────────────────────
AWS_S3_BUCKET=optificial-uploads-prod
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
